{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "premiumUntil": { "type": "string" },
        "subscriptionType": { "type": "string" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    },
    "exam": {
      "title": "Exam",
      "description": "Exam metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slNo": { "type": "number" },
        "name": { "type": "string" },
        "tabName": { "type": "string" },
        "timeLimit": { "type": "number" },
        "status": { "type": "string", "enum": ["live", "draft", "archived"] },
        "markPerQuestion": { "type": "number" },
        "penaltyMark": { "type": "number" },
        "isFree": { "type": "boolean" },
        "price": { "type": "number" }
      },
      "required": ["id", "slNo", "name", "tabName", "timeLimit", "status"]
    },
    "attempt": {
      "title": "Attempt",
      "description": "Exam taking attempt for leaderboard and results",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "examName": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "timeTaken": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "examId", "examName", "username", "email", "score", "totalQuestions", "timeTaken", "completedAt"]
    },
    "transaction": {
      "title": "Transaction",
      "description": "Subscription and exam purchase payment transactions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "examId": { "type": "string" },
        "examName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "transactionId": { "type": "string" },
        "senderNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "createdAt": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["userId", "username", "email", "amount", "paymentMethod", "transactionId", "status", "createdAt"]
    },
    "subscription": {
      "title": "Subscription",
      "description": "Individual exam subscriptions for a specific user",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "examName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified"] },
        "transactionId": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "price": { "type": "number" },
        "updatedAt": { "type": "string" }
      },
      "required": ["examId", "status", "transactionId", "paymentMethod"]
    },
    "settings": {
      "title": "Settings",
      "description": "Application level settings like Apps Script URL",
      "type": "object",
      "properties": {
        "googleAppsScriptUrl": { "type": "string" },
        "gaMeasurementId": { "type": "string" },
        "monthlyPrice": { "type": "number" },
        "yearlyPrice": { "type": "number" },
        "descriptions": { "type": "array" }
      },
      "required": []
    },
    "package": {
      "title": "Package",
      "description": "Subscription package configuration",
      "type": "object",
      "properties": {
        "packagetype": { "type": "string" },
        "packageTitle": { "type": "string" },
        "packageSubtitle": { "type": "string" },
        "baseprice": { "type": "number" },
        "discountType": { "type": "string", "enum": ["flat", "percentage"] },
        "discountValue": { "type": "number" },
        "isActive": { "type": "boolean" },
        "discription": { "type": "array" }
      },
      "required": ["packagetype", "packageTitle", "baseprice", "isActive"]
    },
    "notice": {
      "title": "Notice",
      "description": "System and user notifications/notices",
      "type": "object",
      "properties": {
        "noticeText": { "type": "string" },
        "user": { "type": "string" },
        "isLive": { "type": "boolean" },
        "deeplink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["noticeText", "user", "isLive", "createdAt"]
    },
    "blog": {
      "title": "Blog",
      "description": "Educational blog posts managed by admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "blogTitle": { "type": "string" },
        "blogSlug": { "type": "string" },
        "blogSummary": { "type": "string" },
        "blogText": { "type": "string" },
        "blogImageUrl": { "type": "string" },
        "blogViewCount": { "type": "number" },
        "isBlogVisible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "tags": { "type": "array" }
      },
      "required": ["id", "blogTitle", "blogSlug", "blogText", "isBlogVisible", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Users collections"
    },
    "/users/{userId}/subscriptions/{examId}": {
      "schema": "subscription",
      "description": "User specific exam purchase list"
    },
    "/exams/{examId}": {
      "schema": "exam",
      "description": "Exams config"
    },
    "/examList/{examId}": {
      "schema": "exam",
      "description": "Primary exam list"
    },
    "/packages/{packageId}": {
      "schema": "package",
      "description": "Subscription package list"
    },
    "/attempts/{attemptId}": {
      "schema": "attempt",
      "description": "Leaderboard and score history entries"
    },
    "/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "Pending and verified transactions"
    },
    "/settings/{settingId}": {
      "schema": "settings",
      "description": "Global application settings"
    },
    "/notices/{noticeId}": {
      "schema": "notice",
      "description": "Notice board entries for users or all"
    },
    "/blogs/{blogId}": {
      "schema": "blog",
      "description": "Educational blog articles"
    }
  }
}
