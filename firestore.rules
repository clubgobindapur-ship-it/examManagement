rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEmail(email) {
      return email is string && email.size() >= 3 && email.size() <= 256;
    }

    function isValidUsername(username) {
      return username is string && username.size() >= 2 && username.size() <= 50;
    }

    // Users collection rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId 
                    && request.resource.data.keys().hasAll(['uid', 'username', 'email', 'createdAt'])
                    && request.resource.data.uid == request.auth.uid
                    && isValidUsername(request.resource.data.username)
                    && isValidEmail(request.resource.data.email);
      allow update: if isOwner(userId)
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Exams collection rules
    match /exams/{examId} {
      allow get, list: if true;
      allow create, update: if isAuthenticated() 
                            && isValidId(examId)
                            && request.resource.data.keys().hasAll(['id', 'slNo', 'name', 'tabName', 'timeLimit', 'status'])
                            && request.resource.data.id is string
                            && request.resource.data.slNo is number
                            && request.resource.data.name is string
                            && request.resource.data.tabName is string
                            && request.resource.data.timeLimit is number
                            && request.resource.data.status in ['live', 'draft'];
      allow delete: if isAuthenticated();
    }

    // Attempts collection rules (Leaderboard)
    match /attempts/{attemptId} {
      allow get, list: if true;
      allow create: if isValidId(attemptId)
                    && request.resource.data.keys().hasAll(['id', 'examId', 'examName', 'username', 'email', 'score', 'totalQuestions', 'timeTaken', 'completedAt'])
                    && request.resource.data.id == attemptId
                    && request.resource.data.examId is string
                    && request.resource.data.examName is string
                    && isValidUsername(request.resource.data.username)
                    && isValidEmail(request.resource.data.email)
                    && request.resource.data.score is number
                    && request.resource.data.totalQuestions is number
                    && request.resource.data.timeTaken is number
                    && (!('userId' in request.resource.data) || request.resource.data.userId == null || request.resource.data.userId == request.auth.uid);
      allow update, delete: if false; // Anti-tamper: results cannot be edited or deleted once submitted
    }

    // Settings collection rules
    match /settings/{settingId} {
      allow get: if true;
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }
  }
}
