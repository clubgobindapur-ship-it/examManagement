rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Fallback - Deny all read/write by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // The admin email is configured as 'admin@examportal.com' or the user's registered admin email
      return isAuthenticated() && (
        request.auth.token.email == "admin@examportal.com" || 
        request.auth.token.email == "club.gobindapur@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEmail(email) {
      return email is string && email.size() >= 3 && email.size() <= 256;
    }

    function isValidUsername(username) {
      return username is string && username.size() >= 2 && username.size() <= 50;
    }

    // Users collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      // Nested subscriptions subcollection
      match /subscriptions/{examId} {
        // Users can only view their own subscriptions
        allow read: if isOwner(userId) || isAdmin();
        // Users can only request a pending subscription
        allow create: if isOwner(userId) && request.resource.data.status == "pending";
        // Only admin can verify/update or delete subscriptions
        allow update, delete: if isAdmin();
      }
    }

    // Exams collection rules
    match /exams/{examId} {
      // Publicly readable for active/live/archived quizzes
      allow read: if true;
      // Only admin can manage exam configurations
      allow write: if isAdmin();
    }

    // Exam list collection rules
    match /examList/{examId} {
      // Publicly readable to display index listings
      allow read: if true;
      // Only admin can write to index
      allow write: if isAdmin();
    }

    // Subscription packages collection rules
    match /packages/{packageId} {
      // Publicly readable to display packages to purchase
      allow read: if true;
      // Only admin can edit or manage package offers
      allow write: if isAdmin();
    }

    // Attempts collection rules (Leaderboard & Results)
    match /attempts/{attemptId} {
      // Publicly list and read scoreboard and results
      allow get, list: if true;
      // Prevent cheating: Users can submit an attempt but must set their matching auth userId (or null for guest)
      allow create: if isValidId(attemptId)
                    && request.resource.data.keys().hasAll(['id', 'examId', 'examName', 'username', 'email', 'score', 'totalQuestions', 'timeTaken', 'completedAt'])
                    && request.resource.data.id == attemptId
                    && request.resource.data.examId is string
                    && request.resource.data.examName is string
                    && isValidUsername(request.resource.data.username)
                    && isValidEmail(request.resource.data.email)
                    && request.resource.data.score is number
                    && request.resource.data.totalQuestions is number
                    && request.resource.data.timeTaken is number
                    && (!('userId' in request.resource.data) || request.resource.data.userId == null || request.resource.data.userId == request.auth.uid);
      // Immutable: Attempt entries cannot be edited or deleted to prevent fraud
      allow update, delete: if false;
    }

    // Transactions collection rules
    match /transactions/{transactionId} {
      // Users can only read their own payment logs, Admins can inspect all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Users can only create a pending transaction under their own account
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid 
                    && request.resource.data.status == "pending";
      // Only administrators can verify, edit, or delete transactions
      allow update, delete: if isAdmin();
    }

    // Settings collection rules
    match /settings/{settingId} {
      // General settings (like googleAppsScriptUrl, monthlyPrice) are readable by all. 
      // Sensitive document "admin" (admin credentials) can ONLY be read by an admin!
      allow read: if settingId != "admin" || isAdmin();
      // Only admin can edit settings
      allow write: if isAdmin();
    }

    // Notices collection rules
    match /notices/{noticeId} {
      // Publicly readable notices
      allow read: if true;
      // Only admin can publish notices
      allow write: if isAdmin();
    }

    // Blogs collection rules
    match /blogs/{blogId} {
      // Readable by anyone if the blog is visible, or if the requester is an admin
      allow get, list: if resource.data.isBlogVisible == true || isAdmin();
      // Only admins can create or delete blogs
      allow create, delete: if isAdmin();
      // Admins can update anything. Normal users can only update by incrementing blogViewCount by exactly 1.
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['blogViewCount']) &&
        request.resource.data.blogViewCount == resource.data.blogViewCount + 1
      );
    }
  }
}
